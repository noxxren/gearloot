# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/honokit_dev

# Security
ENCRYPTION_KEY=  # Generate with: bun run -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=      # Generate with: bun run -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
